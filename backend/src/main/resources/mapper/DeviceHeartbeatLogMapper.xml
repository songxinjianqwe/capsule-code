<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xinjian.capsulecode.mapper.DeviceHeartbeatLogMapper">

    <insert id="insert">
        INSERT INTO device_heartbeat_log (device_id, heartbeat_at)
        VALUES (#{deviceId}, #{heartbeatAt})
    </insert>

    <select id="selectByTimestampRange"
            resultType="com.xinjian.capsulecode.model.DeviceHeartbeatLog">
        SELECT id, device_id, heartbeat_at
        FROM device_heartbeat_log
        WHERE heartbeat_at >= #{since}
          AND heartbeat_at &lt;= #{until}
        ORDER BY device_id, heartbeat_at ASC
    </select>

</mapper>
