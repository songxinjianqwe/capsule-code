# 复制此文件为 .env 并填入你的值；.env 已 gitignored 不会入库

# ── Claude CLI 登录（二选一）─────────────────────────────────
# 方式 A（推荐 Claude 订阅用户）：在宿主机先 `claude login` 一次，然后留空此项
#                                 compose 里会把 ~/.claude 挂进容器
# 方式 B（API key 直连）：填入你的 Anthropic API key
ANTHROPIC_API_KEY=

# ── 讯飞语音 SDK 凭证（4 个都要填，否则 Android app 录音不可用）──
# 注册地址: https://www.xfyun.cn/  → 控制台 → 创建应用 → 实时语音转写
XFYUN_APPID=
XFYUN_APIKEY=
XFYUN_APISECRET=
XFYUN_SECRETKEY=

# ── 可选：宿主机挂载点 ─────────────────────────────────────
# 你想让 Claude 操作的项目目录（容器里看到的就是 /workspace）
WORKSPACE_DIR=./workspace
# Claude CLI 配置目录（含登录态 / settings.json），默认用当前登录用户的 ~/.claude
# CLAUDE_HOME=~/.claude
